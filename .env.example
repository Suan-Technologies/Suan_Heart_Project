# =============================================================================
# Environment Variables Example
# =============================================================================
# Copy this file to `.env` and fill in your actual values.
# Vite automatically loads .env files — variables must start with VITE_ to be
# accessible in the client-side code via import.meta.env.
# =============================================================================

# ─── App ───────────────────────────────────────────────────────────────────
VITE_APP_NAME=TrueBond
VITE_APP_VERSION=1.0.0
VITE_APP_ENV=production

# ─── API Base URL ──────────────────────────────────────────────────────────
# Environment ke hisaab se auto-switch hoga. Sirf ek hi set karo.
VITE_API_BASE_URL=https://goapi.up.railway.app/
# ─── API Settings ───────────────────────────────────────────────────────────
VITE_API_TIMEOUT=30000
VITE_API_RETRY_COUNT=1

# ─── Optional: Analytics / Third-party ──────────────────────────────────────
# VITE_GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX
# VITE_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
# VITE_FIREBASE_API_KEY=xxxxxxxx

# ─── Optional: Social Auth ────────────────────────────────────────────────
# VITE_GOOGLE_CLIENT_ID=xxxx.apps.googleusercontent.com
# VITE_FACEBOOK_APP_ID=xxxx
